# =============================================================================
# Generation functions
# =============================================================================

VALID_PHASES = {"readiness", "deployment", "performance", "conformance"}


def generate_check(check_name, phase, description, output_dir):
    """Generate files for a new check."""
    func_name = check_name_to_func_name(check_name)
    test_name = "TestCheck" + func_name
    file_base = to_snake_case(func_name)
    package = sanitize_package_name(os.path.basename(output_dir))

    if not description:
        description = f"Validates {check_name}"

    # Source file
    check_file = os.path.join(output_dir, file_base + "_check.go")
    write_file(
        check_file,
        render(
            CHECK_SOURCE_TEMPLATE,
            Package=package,
            FuncName=func_name,
            TestName=test_name,
            CheckName=check_name,
            Phase=phase,
            Description=description,
        ),
    )

    # Test file
    test_file = os.path.join(output_dir, file_base + "_check_test.go")
    write_file(
        test_file,
        render(
            CHECK_TEST_TEMPLATE,
            Package=package,
            FuncName=func_name,
            TestName=test_name,
            CheckName=check_name,
            Phase=phase,
        ),
    )

    # Unit test file
    unit_test_file = os.path.join(output_dir, file_base + "_check_unit_test.go")
    write_file(
        unit_test_file,
        render(
            CHECK_UNIT_TEST_TEMPLATE,
            Package=package,
            FuncName=func_name,
            CheckName=check_name,
        ),
    )

    # Recipe file
    recipe_file = os.path.join(output_dir, file_base + "_recipe.yaml")
    write_file(
        recipe_file,
        render(CHECK_RECIPE_TEMPLATE, CheckName=check_name, Phase=phase),
    )

    # README file
    readme_file = os.path.join(output_dir, file_base + "_README.md")
    write_file(
        readme_file,
        render(
            CHECK_README_TEMPLATE,
            CheckName=check_name,
            FuncName=func_name,
            TestName=test_name,
            Phase=phase,
            CheckFile=os.path.basename(check_file),
            TestFile=os.path.basename(test_file),
            UnitTestFile=os.path.basename(unit_test_file),
            RecipeFile=os.path.basename(recipe_file),
            Description=description,
        ),
    )

    print("✓ Generated check:")
    for f in [check_file, test_file, unit_test_file, recipe_file, readme_file]:
        print(f"  - {f}")
    print(f"\nSee {readme_file} for instructions.")


def generate_constraint_validator(constraint_name, phase, description, output_dir):
    """Generate files for a new constraint validator."""
    func_name = constraint_to_func_name(constraint_name)
    test_name = "Test" + func_name
    file_base = to_snake_case(func_name)
    package = sanitize_package_name(os.path.basename(output_dir))

    if not description:
        description = f"Validates {constraint_name} constraint"

    # Source file
    validator_file = os.path.join(output_dir, file_base + "_constraint.go")
    write_file(
        validator_file,
        render(
            CONSTRAINT_SOURCE_TEMPLATE,
            Package=package,
            FuncName=func_name,
            TestName=test_name,
            ConstraintName=constraint_name,
            Phase=phase,
            Description=description,
        ),
    )

    # Test file
    test_file = os.path.join(output_dir, file_base + "_constraint_test.go")
    write_file(
        test_file,
        render(
            CONSTRAINT_TEST_TEMPLATE,
            Package=package,
            FuncName=func_name,
            TestName=test_name,
            ConstraintName=constraint_name,
            Phase=phase,
        ),
    )

    # Unit test file
    unit_test_file = os.path.join(
        output_dir, file_base + "_constraint_unit_test.go"
    )
    write_file(
        unit_test_file,
        render(
            CONSTRAINT_UNIT_TEST_TEMPLATE,
            Package=package,
            FuncName=func_name,
            ConstraintName=constraint_name,
        ),
    )

    # Recipe file
    recipe_file = os.path.join(output_dir, file_base + "_recipe.yaml")
    write_file(
        recipe_file,
        render(
            CONSTRAINT_RECIPE_TEMPLATE,
            ConstraintName=constraint_name,
            Phase=phase,
        ),
    )

    # README file
    readme_file = os.path.join(output_dir, file_base + "_README.md")
    write_file(
        readme_file,
        render(
            CONSTRAINT_README_TEMPLATE,
            ConstraintName=constraint_name,
            FuncName=func_name,
            TestName=test_name,
            Phase=phase,
            ValidatorFile=os.path.basename(validator_file),
            TestFile=os.path.basename(test_file),
            UnitTestFile=os.path.basename(unit_test_file),
            RecipeFile=os.path.basename(recipe_file),
            Description=description,
        ),
    )

    print("✓ Generated constraint validator:")
    for f in [validator_file, test_file, unit_test_file, recipe_file, readme_file]:
        print(f"  - {f}")
    print(f"\nSee {readme_file} for instructions.")


