"""Generate scaffolding for a new validation check or constraint validator.

Usage:
  Check (no expected value, yes/no validation):
    tools/generate-validator --check operator-health --phase deployment

  Constraint (has expected value from recipe):
    tools/generate-validator --constraint Deployment.gpu-operator.version --phase deployment

  Via Make:
    make generate-validator ARGS="--check operator-health --phase deployment"
"""

import argparse
import os
import re
import sys

# =============================================================================
# Name conversion helpers
# =============================================================================


def check_name_to_func_name(name):
    """Convert a check name to a Go function name.

    "operator-health" -> "OperatorHealth"
    """
    parts = re.split(r"[-_]", name)
    return "".join(p[0].upper() + p[1:] for p in parts if p)


def constraint_to_func_name(constraint):
    """Convert a constraint name to a Go function name.

    "Deployment.gpu-operator.version" -> "DeploymentGpuOperatorVersion"
    """
    parts = re.split(r"[.\-]", constraint)
    return "".join(p[0].upper() + p[1:] for p in parts if p)


def to_snake_case(s):
    """Convert CamelCase to snake_case.

    "GPUOperatorVersion" -> "g_p_u_operator_version"
    """
    result = []
    for i, c in enumerate(s):
        if i > 0 and c.isupper():
            result.append("_")
        result.append(c)
    return "".join(result).lower()


def sanitize_package_name(name):
    """Convert a directory name to a valid Go package name.

    "gen-test" -> "gentest"
    """
    return name.replace("-", "").lower()


# =============================================================================
# Template rendering
# =============================================================================


def render(template, **kwargs):
    """Replace {{.Key}} placeholders with values."""
    result = template
    for key, value in kwargs.items():
        result = result.replace("{{." + key + "}}", value)
    return result


def write_file(path, content):
    """Write content to a file."""
    with open(path, "w") as f:
        f.write(content)


