# Main
# =============================================================================


def main():
    parser = argparse.ArgumentParser(
        description="Generate scaffolding for a new check or constraint validator",
        epilog="""\
examples:
  %(prog)s --check operator-health --phase deployment
  %(prog)s --constraint Deployment.gpu-operator.version --phase deployment
  %(prog)s --check my-check --phase readiness --output /tmp/test-gen
""",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument(
        "--check",
        help="Check name (e.g., operator-health) - for yes/no validations",
    )
    parser.add_argument(
        "--constraint",
        help="Constraint name (e.g., Deployment.my-app.version) - for value comparisons",
    )
    parser.add_argument(
        "--phase",
        required=True,
        choices=sorted(VALID_PHASES),
        help="Validation phase",
    )
    parser.add_argument(
        "--description",
        default="",
        help="Description of what this validator checks",
    )
    parser.add_argument(
        "--output",
        default="",
        help="Output directory (default: pkg/validator/checks/<phase>)",
    )

    args = parser.parse_args()

    # Must specify either check or constraint
    if not args.check and not args.constraint:
        parser.error("must specify either --check or --constraint")
    if args.check and args.constraint:
        parser.error("cannot specify both --check and --constraint")

    # Default output directory
    output_dir = args.output
    if not output_dir:
        output_dir = os.path.join(
            os.getcwd(), "pkg", "validator", "checks", args.phase
        )

    # Check if output directory exists
    if not os.path.isdir(output_dir):
        print(f"Error: output directory does not exist: {output_dir}", file=sys.stderr)
        sys.exit(1)

    if args.check:
        generate_check(args.check, args.phase, args.description, output_dir)
    else:
        generate_constraint_validator(
            args.constraint, args.phase, args.description, output_dir
        )


if __name__ == "__main__":
    main()
