#!/bin/bash
set -euo pipefail

# Dir setup
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
. "${DIR}/common"
ROOT=$(dirname "${DIR}")

# Check required tools
has_tools kubectl

# Prompt user to confirm cleanup
read -p "Are you sure you want to clean up aicr resources? (y/N): " confirm
if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
    echo "Cleanup aborted."
    exit 0
fi

msg "Cleaning up aicr resources..."

# Delete aicr Kubernetes resources, don't fail if they don't exist
kubectl -n gpu-operator delete job aicr || true
kubectl -n gpu-operator delete sa aicr || true
kubectl -n gpu-operator delete role aicr || true
kubectl -n gpu-operator delete rolebinding aicr || true
kubectl delete clusterrole aicr || true
kubectl delete clusterrolebinding aicr || true

msg "AICR resources cleanup complete."